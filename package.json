{
  "name": "chaincred",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "dev:api": "bun run --filter @chaincred/api dev",
    "dev:frontend": "bun run --filter @chaincred/frontend dev",
    "migrate": "bun run packages/common/src/db-migrate.ts",
    "seed": "bun run packages/api/src/scripts/seed-wallets.ts",
    "e2e": "bash scripts/e2e-test.sh"
  }
}
